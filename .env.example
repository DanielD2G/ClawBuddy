# Database
DATABASE_URL="postgresql://agentbuddy:agentbuddy@localhost:5433/agentbuddy"

# Redis
REDIS_URL="redis://localhost:6380"

# Qdrant
QDRANT_URL="http://localhost:6333"

# MinIO (S3-compatible)
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="agentbuddy"
MINIO_SECRET_KEY="agentbuddy123"
MINIO_BUCKET="agentbuddy"

# Encryption secret for API key storage (change in production!)
ENCRYPTION_SECRET="change-me-to-a-random-secret"

# AI Providers — set the provider you want to use and its API key
# AI_PROVIDER controls chat/LLM (openai | gemini | claude)
# EMBEDDING_PROVIDER controls embeddings (openai | gemini) — Claude has no embeddings API
AI_PROVIDER="openai"
EMBEDDING_PROVIDER="openai"

# Provider API keys (only the ones for your selected providers are required)
OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# Debug — set to "1" to enable verbose agent logging
# DEBUG_AGENT="1"
