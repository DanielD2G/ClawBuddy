{
  "name": "@clawbuddy/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "fmt": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "fmt:check": "prettier --check \"src/**/*.{ts,tsx,json}\""
  },
  "dependencies": {
    "@clawbuddy/shared": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@clawbuddy/tsconfig": "workspace:*",
    "@eslint/js": "^9",
    "@tailwindcss/vite": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "globals": "^16",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6"
  },
  "packageManager": "bun@1.3.5",
  "patchedDependencies": {
    "playwright-core@1.58.2": "patches/playwright-core@1.58.2.patch"
  }
}
