{
  "name": "clawbuddy",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run db:generate && bun --filter './apps/*' dev",
    "build": "bun --filter './apps/*' build",
    "fmt": "bun run format",
    "lint": "bun run lint:files apps/api/src apps/web/src packages/shared/src test eslint.config.mjs packages/eslint-config",
    "lint:files": "bun x eslint --config ./eslint.config.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "vitest run",
    "typecheck": "bun --filter '*' type-check",
    "type-check": "bun --filter '*' type-check",
    "clean": "rm -rf node_modules apps/*/dist apps/*/node_modules packages/*/node_modules",
    "docker:up": "docker compose -f docker-compose.dev.yml --profile infra up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "db:generate": "bun --filter @clawbuddy/api db:generate",
    "db:push": "bun --filter @clawbuddy/api db:push"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "globals": "^16",
    "prettier": "^3",
    "vitest": "^2.1.9",
    "ws": "^8.19.0"
  },
  "packageManager": "bun@1.3.5",
  "patchedDependencies": {
    "playwright-core@1.58.2": "patches/playwright-core@1.58.2.patch"
  }
}
